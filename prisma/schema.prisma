generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ==================== AUTH & USERS ====================

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  avatar       String?
  role         String   @default("content_writer") // owner, manager, content_writer, shooter, editor, posting
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  workspaces       WorkspaceMember[]
  createdPages     Page[]            @relation("PageCreator")
  favorites        Favorite[]
  assignedReminders Reminder[]       @relation("ReminderAssignee")
  createdReminders  Reminder[]       @relation("ReminderCreator")
  sentMessages     ChatMessage[]     @relation("MessageSender")
  receivedMessages ChatMessage[]     @relation("MessageReceiver")
  activityLogs     ActivityLog[]
  comments         Comment[]
  sessions         Session[]
  accounts         Account[]
  calendarRows     CalendarRow[]     @relation("RowAssignee")
  calendarShoots   CalendarRow[]     @relation("RowShootPerson")
  calendarEdits    CalendarRow[]     @relation("RowEditor")
  cooldown         UserCooldown?
  notifications    Notification[]    @relation("UserNotifications")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

// ==================== WORKSPACE ====================

model Workspace {
  id        String   @id @default(cuid())
  name      String
  icon      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members   WorkspaceMember[]
  pages     Page[]
  databases Database[]
  clients   Client[]
}

model WorkspaceMember {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String
  role        String   @default("content_writer")
  joinedAt    DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
}

// ==================== PAGES & BLOCKS ====================

model Page {
  id              String   @id @default(cuid())
  title           String   @default("Untitled")
  icon            String?
  coverImage      String?
  content         String?  // JSON - TipTap document content
  parentId        String?  // Self-relation for nested pages
  workspaceId     String
  createdById     String
  isTemplate      Boolean  @default(false)
  isTrashed       Boolean  @default(false)
  shareToken      String?  @unique
  sharePermission String?  // "view" | "edit" | null
  position        Int      @default(0)
  pageType        String   @default("general") // "general" | "script_page" | "calendar_page"
  clientId        String?  // Links page to a specific Client
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  parent    Page?  @relation("PageHierarchy", fields: [parentId], references: [id])
  children  Page[] @relation("PageHierarchy")
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy User      @relation("PageCreator", fields: [createdById], references: [id])
  favorites Favorite[]
  databases Database[]
  comments  Comment[]
  activityLogs ActivityLog[]
  scripts   Script[]
  client    Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  calendarRows CalendarRow[]
}

// ==================== SCRIPTS (per-client scripting) ====================

model Script {
  id           String   @id @default(cuid())
  pageId       String
  scriptNumber Int
  title        String   @default("")
  reelLink     String?
  content      String?  // Rich text content (plain text for script page)
  status       String   @default("draft") // draft, shoot_pending, shoot_done, editing, approved, posted
  assigneeId   String?
  googleDocId  String?  // Google Doc ID for sync (TODO: activate with API key)
  lastSyncedAt DateTime? // Timestamp of last successful Google Doc sync
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  page         Page    @relation(fields: [pageId], references: [id], onDelete: Cascade)
  calendarRows CalendarRow[]

  @@unique([pageId, scriptNumber])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  pageId    String
  position  Int      @default(0)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  page Page @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@unique([userId, pageId])
}

// ==================== CLIENTS (per-client script & calendar pages) ====================

model Client {
  id               String   @id @default(cuid())
  name             String
  emoji            String?  @default("🏢") // Display icon for client
  googleDocId      String?  // TODO: Google Doc ID for script sync (fill after API key)
  driveFolder      String?  // TODO: Google Drive folder ID for video uploads (fill after API key)
  videoFolderId    String?  // Google Drive folder ID for Videos
  thumbnailFolderId String? // Google Drive folder ID for Thumbnails
  workspaceId      String
  createPermission String   @default("manager") // "manager" | "all" — which roles can add clients
  settings         String?  // JSON: { columnVisibility: { [role]: [colId, ...] } }
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  pages     Page[]    // script_page and calendar_page linked to this client

  @@index([workspaceId])
}

// ==================== CALENDAR (per-client tracker) ====================

model CalendarRow {
  id             String    @id @default(cuid())
  pageId         String
  date           DateTime?
  postDate       DateTime?
  shootDate      DateTime?
  title          String    @default("")
  scriptId       String?
  scriptDetails  String?
  caption        String?
  thumbnail      String?
  status         String    @default("idea") // idea, scripted, shooting, editing, ready, posted
  shootStatus    String    @default("pending") // done, pending, happening
  shootPersonId  String?
  editStatus     String    @default("pending") // done, pending, happening
  editorId       String?
  assigneeId     String?
  approvalStatus String?   // "Approved" or "Changes"
  approvalMsg    String?
  driveLink      String?
  socialMedia    String?
  position       Int       @default(0)
  keywords       String?
  link           String?
  customCols     String?   // JSON representation of custom columns
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  page        Page    @relation(fields: [pageId], references: [id], onDelete: Cascade)
  script      Script? @relation(fields: [scriptId], references: [id], onDelete: SetNull)
  assignee    User?   @relation("RowAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  shootPerson User?   @relation("RowShootPerson", fields: [shootPersonId], references: [id], onDelete: SetNull)
  editor      User?   @relation("RowEditor", fields: [editorId], references: [id], onDelete: SetNull)

  @@index([pageId])
}

// ==================== DATABASES (Notion-style) ====================

model Database {
  id          String   @id @default(cuid())
  title       String   @default("Untitled Database")
  icon        String?
  pageId      String?
  workspaceId String
  schema      String   // JSON - column definitions [{id, name, type, options}]
  viewConfig  String?  // JSON - view configs (table/kanban/calendar/gallery)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  page      Page?      @relation(fields: [pageId], references: [id], onDelete: Cascade)
  workspace Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  rows      DatabaseRow[]
}

model DatabaseRow {
  id         String   @id @default(cuid())
  databaseId String
  properties String   // JSON - {columnId: value}
  position   Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  database Database @relation(fields: [databaseId], references: [id], onDelete: Cascade)
}

// ==================== REMINDERS ====================

model Reminder {
  id           String    @id @default(cuid())
  title        String
  description  String?
  details      String?
  assigneeId   String
  creatorId    String
  endDate      DateTime
  
  reminderSent Boolean   @default(false)
  halfTimeSent Boolean   @default(false)
  
  notif1Sent   Boolean   @default(false) // Triggered at X hours remaining
  notif2Sent   Boolean   @default(false) // Triggered at Y hours remaining
  notif3Sent   Boolean   @default(false) // Triggered at deadline

  status       String    @default("pending") // pending, in_progress, in_review, completed, overdue
  reviewStatus String?   // "pending_review", "approved", "changes_requested"
  
  attachmentUrl  String?
  attachmentName String?
  attachmentType String?

  parentId     String?   // For re-assignment chain
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  completedAt  DateTime?

  assignee  User       @relation("ReminderAssignee", fields: [assigneeId], references: [id])
  creator   User       @relation("ReminderCreator", fields: [creatorId], references: [id])
  parent    Reminder?  @relation("ReminderChain", fields: [parentId], references: [id])
  children  Reminder[] @relation("ReminderChain")
}

// ==================== INTERNAL CHAT & NOTIFICATIONS ====================

model ChatMessage {
  id         String   @id @default(cuid())
  content    String?
  mediaUrl   String?  // For images/videos
  mediaType  String?  // "image" | "video" | "file"
  senderId   String
  receiverId String?  // Null if group chat
  isGroup    Boolean  @default(false)
  replyToId  String?  // ID of the message this replies to
  mentions   String?  // JSON string array of user IDs
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  sender   User         @relation("MessageSender", fields: [senderId], references: [id])
  receiver User?        @relation("MessageReceiver", fields: [receiverId], references: [id])
  replyTo  ChatMessage? @relation("MessageReplies", fields: [replyToId], references: [id])
  replies  ChatMessage[] @relation("MessageReplies")
}

model UserCooldown {
  id        String   @id @default(cuid())
  userId    String   @unique
  endTime   DateTime
  reason    String?
  createdAt DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   // "mention" | "task" | "system" | "chat"
  link      String?  // Optional URL to navigate to
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
}

// ==================== COMMENTS & ACTIVITY ====================

model Comment {
  id        String   @id @default(cuid())
  content   String
  pageId    String
  userId    String
  createdAt DateTime @default(now())

  page Page @relation(fields: [pageId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])
}

model ActivityLog {
  id        String   @id @default(cuid())
  action    String   // "created", "edited", "deleted", "shared", "assigned"
  userId    String
  pageId    String?
  metadata  String?  // JSON
  createdAt DateTime @default(now())

  user User  @relation(fields: [userId], references: [id])
  page Page? @relation(fields: [pageId], references: [id], onDelete: SetNull)
}
